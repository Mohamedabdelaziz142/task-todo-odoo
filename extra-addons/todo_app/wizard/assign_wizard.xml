<odoo> 
  <record id="change_state_form_view" model="ir.ui.view">
    <field name="name">Assign task form</field>
    <field name="model">todo.assign.task</field>
    <field name="arch" type="xml">
        <form>
           <group>
                  <field name="assigned_to"/>
                
            </group>
            <footer>
                  <button string ="Confirm" type="object" name="action_assign" class="btn-primary"/>
                  <button string ="Cancel" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>

    <record id="assign_task_wizard_action" model="ir.actions.act_window">
        <field name="name">Assign task</field>
        <field name="res_model">todo.assign.task</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>


</odoo>